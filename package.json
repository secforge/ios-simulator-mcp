{
  "name": "@secforge/ios-simulator-mcp",
  "version": "1.6.0",
  "description": "MCP server for interacting with iOS simulators locally or remotely via SSH",
  "bin": {
    "ios-simulator-mcp": "build/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/secforge/ios-simulator-mcp.git"
  },
  "files": [
    "build",
    "package.json"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "start": "node build/index.js",
    "watch": "tsc --watch",
    "predev": "npm run build",
    "dev": "npx @modelcontextprotocol/inspector node build/index.js"
  },
  "keywords": [
    "ios",
    "simulator",
    "mcp",
    "modelcontextprotocol",
    "ssh",
    "remote",
    "wsl"
  ],
  "author": {
    "name": "Joshua Yoes",
    "url": "https://joshuayoes.com"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ssh2": "^1.15.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "0.16.8",
    "@types/node": "^22.12.0",
    "@types/ssh2": "^1.15.0",
    "typescript": "^5.5.4"
  }
}
